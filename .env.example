# Firebase Web App config — copy this file to .env.local and fill in your values.
# Find these in Firebase Console → Project settings → General → Your apps → Web app → SDK setup.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics in the browser.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Set to "true" to run the app against the local Firebase Emulator Suite.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
